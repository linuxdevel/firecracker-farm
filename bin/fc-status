#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"
# shellcheck source=../lib/network.sh
source "$SCRIPT_DIR/../lib/network.sh"
# shellcheck source=../lib/firecracker.sh
source "$SCRIPT_DIR/../lib/firecracker.sh"
fc_load_config

fc_status_usage() {
  cat <<EOF
Usage: fc-status <name>

Show detailed runtime status of a Firecracker VM instance.

Displays a vertical key-value summary including:
  Name, Status, PID, vCPUs, Memory, Disk, IP, TAP, Bridge, Uptime

Options:
  -h, --help   Show this help text

Example:
  fc-status myvm
EOF
}

fc_status_main() {
  case "${1:-}" in
    -h|--help)
      fc_status_usage
      return 0
      ;;
  esac

  fc_require_argument_count "$#" 1 "Usage: fc-status <name>" || return 1

  if ! fc_running_as_root; then
    fc_reexec_with_sudo "$0" "$@"
  fi

  local info_output
  info_output=$(fc_firecracker_vm_info "$1") || return 1

  # Parse and display vertically
  local key value
  while IFS='=' read -r key value; do
    case "$key" in
      VM_NAME)  printf '%-10s %s\n' "Name:" "$value" ;;
      STATUS)   printf '%-10s %s\n' "Status:" "$value" ;;
      PID)      printf '%-10s %s\n' "PID:" "$value" ;;
      VCPUS)    printf '%-10s %s\n' "vCPUs:" "$value" ;;
      MEMORY)   printf '%-10s %s MiB\n' "Memory:" "$value" ;;
      DISK)     printf '%-10s %s\n' "Disk:" "$value" ;;
      IP)       printf '%-10s %s\n' "IP:" "$value" ;;
      TAP)      printf '%-10s %s\n' "TAP:" "$value" ;;
      BRIDGE)   printf '%-10s %s\n' "Bridge:" "$value" ;;
      UPTIME)   printf '%-10s %s\n' "Uptime:" "$value" ;;
    esac
  done <<< "$info_output"
}

fc_status_main "$@"
