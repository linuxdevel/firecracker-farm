#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"
# shellcheck source=../lib/network.sh
source "$SCRIPT_DIR/../lib/network.sh"
# shellcheck source=../lib/firecracker.sh
source "$SCRIPT_DIR/../lib/firecracker.sh"
fc_load_config

fc_ssh_usage() {
    cat <<EOF
Usage: fc-ssh [options] <name> [-- ssh-args...]

Open an SSH session to a running Firecracker VM.

Options:
  --identity PATH   Use a specific private key file
  --copy-id         Copy SSH public key to the guest (uses ssh-copy-id)
  -h, --help        Show this help text

Examples:
  fc-ssh myvm                      # interactive shell
  fc-ssh myvm -- ls -la /tmp       # run a remote command
  fc-ssh myvm -- -L 8080:lo:80     # SSH port forward
  fc-ssh myvm --copy-id            # install SSH key on guest
EOF
}

fc_ssh_resolve_ip() {
    local vm_name=$1
    local metadata_path mac_address bridge_name ip

    metadata_path=$(fc_firecracker_vm_metadata_path "$vm_name")
    [[ -f "$metadata_path" ]] || {
        fc_error "instance metadata not found: $metadata_path"
        return 1
    }

    mac_address=$(fc_firecracker_env_get "$metadata_path" "MAC_ADDRESS")
    bridge_name=$(fc_firecracker_env_get "$metadata_path" "BRIDGE_NAME")
    bridge_name=${bridge_name:-$FC_DEFAULT_BRIDGE}

    [[ -n "$mac_address" ]] || {
        fc_error "MAC address not found in metadata for VM $vm_name"
        return 1
    }

    ip=$(fc_network_resolve_guest_ip "$mac_address" "$bridge_name") || {
        fc_error "could not resolve IP for VM $vm_name (MAC $mac_address)"
        fc_error "is the VM running and connected to the network?"
        return 1
    }

    printf '%s\n' "$ip"
}

fc_ssh_main() {
    local vm_name=
    local identity=
    local copy_id=0
    local ssh_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                fc_ssh_usage
                return 0
                ;;
            -V|--version)
                printf 'firecracker-farm %s\n' "$(fc_version)"
                return 0
                ;;
            --identity)
                if [[ $# -lt 2 ]]; then
                    fc_error "--identity requires a path"
                    return 1
                fi
                identity=$2
                shift 2
                ;;
            --copy-id)
                copy_id=1
                shift
                ;;
            --)
                shift
                ssh_args=("$@")
                break
                ;;
            --*)
                fc_error "Unknown option: $1"
                fc_ssh_usage >&2
                return 1
                ;;
            *)
                if [[ -n "$vm_name" ]]; then
                    fc_error "Usage: fc-ssh [options] <name> [-- ssh-args...]"
                    return 1
                fi
                vm_name=$1
                shift
                ;;
        esac
    done

    if [[ -z "$vm_name" ]]; then
        fc_error "Usage: fc-ssh [options] <name> [-- ssh-args...]"
        return 1
    fi

    local guest_ip guest_user metadata_path
    guest_ip=$(fc_ssh_resolve_ip "$vm_name") || return 1

    metadata_path=$(fc_firecracker_vm_metadata_path "$vm_name")
    guest_user=$(fc_firecracker_env_get "$metadata_path" "GUEST_USER")
    guest_user=${guest_user:-$FC_GUEST_USER}

    local ssh_opts=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null)
    if [[ -n "$identity" ]]; then
        ssh_opts+=(-i "$identity")
    fi

    if (( copy_id )); then
        local copy_id_opts=()
        if [[ -n "$identity" ]]; then
            copy_id_opts+=(-i "$identity")
        fi
        exec ssh-copy-id "${copy_id_opts[@]}" "${guest_user}@${guest_ip}"
    fi

    exec ssh "${ssh_opts[@]}" "${guest_user}@${guest_ip}" "${ssh_args[@]}"
}

fc_ssh_main "$@"
