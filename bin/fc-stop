#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"
# shellcheck source=../lib/firecracker.sh
source "$SCRIPT_DIR/../lib/firecracker.sh"
fc_load_config

fc_stop_usage() {
  cat <<EOF
Usage: fc-stop [--direct] [--force] <name>

Stop a running Firecracker VM instance.

By default, stops the VM through its systemd service unit
(disable + stop). With --direct, sends SIGTERM to the Firecracker
process directly without involving systemd.

Options:
  --direct     Stop the VM process directly (used by systemd ExecStop)
  --force      Skip SIGTERM, send SIGKILL immediately + cgroup cleanup
  -h, --help   Show this help text

Example:
  fc-stop myvm
  fc-stop --direct myvm
  fc-stop --force myvm
EOF
}

fc_stop_systemd_unit_name() {
  local vm_name=$1
  printf 'firecracker@%s.service\n' "$vm_name"
}

fc_stop_main() {
  local direct=0
  local force=0

  # Parse flags before positional args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) fc_stop_usage; return 0 ;;
      --direct) direct=1; shift ;;
      --force) force=1; shift ;;
      --*) fc_error "Unknown option: $1"; return 1 ;;
      *) break ;;
    esac
  done

  fc_require_argument_count "$#" 1 "Usage: fc-stop [--direct] [--force] <name>" || return 1

  if (( ! direct && ! force )) && ! fc_running_as_root; then
    fc_reexec_with_sudo "$0" "$@"
  fi

  if (( direct )); then
    fc_firecracker_stop "$1" "$force"
    return 0
  fi

  if (( force )); then
    if ! fc_running_as_root; then
      fc_reexec_with_sudo "$0" --force "$@"
    fi
    fc_firecracker_stop "$1" 1
    systemctl disable "$(fc_stop_systemd_unit_name "$1")" 2>/dev/null || true
    return 0
  fi

  fc_command_exists systemctl || {
    fc_error "systemctl is required to stop VMs through systemd"
    return 1
  }

  systemctl disable --now "$(fc_stop_systemd_unit_name "$1")"
}

fc_stop_main "$@"
