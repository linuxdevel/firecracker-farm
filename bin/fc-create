#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"
# shellcheck source=../lib/image.sh
source "$SCRIPT_DIR/../lib/image.sh"
# shellcheck source=../lib/network.sh
source "$SCRIPT_DIR/../lib/network.sh"
fc_load_config

fc_create_usage() {
  cat >&2 <<EOF
Usage: fc-create <name> [OPTIONS]

Creates a persistent per-instance rootfs clone and metadata.

Guest credentials (required):
  --guest-user USER      Username for the VM guest (prompted if omitted).
  --ssh-key-file PATH    Path to an SSH public key file (prompted if omitted).
  --ssh-key KEY          SSH public key string (prompted if omitted).
                         Mutually exclusive with --ssh-key-file.

Resource options:
  --disk-size SIZE       Disk size (e.g. 20G, 512M). Prompted if omitted.
  --vcpus N              Number of vCPUs (integer >= 1, default: $FC_DEFAULT_VCPUS).
  --memory SIZE          Memory allocation (e.g. 2048m, 2g). Minimum 128 MiB.
                         Default: ${FC_DEFAULT_MEMORY_MIB}m.

  -h, --help             Show this help text.

When run interactively (terminal attached), omitted credential options are
prompted. When run non-interactively, all credentials must be provided via
flags.

Examples:
  fc-create myvm --disk-size 20G
  fc-create myvm --guest-user ops --ssh-key-file ~/.ssh/id_ed25519.pub --disk-size 20G
  fc-create myvm --guest-user ops --ssh-key "ssh-ed25519 AAAA..." --disk-size 20G
EOF
}

fc_create_prompt_guest_user() {
  local response=
  printf 'Guest username: ' >&2
  IFS= read -r response || return 1
  if [[ -z "$response" ]]; then
    fc_error "guest username cannot be empty"
    return 1
  fi
  printf '%s\n' "$response"
}

fc_create_prompt_ssh_key() {
  local response=
  printf 'SSH public key (paste key or path to .pub file): ' >&2
  IFS= read -r response || return 1
  if [[ -z "$response" ]]; then
    fc_error "SSH key cannot be empty"
    return 1
  fi
  printf '%s\n' "$response"
}

fc_create_resolve_ssh_key() {
  local input=$1

  # If it looks like an SSH public key (starts with ssh- or ecdsa-), use it directly
  if [[ "$input" =~ ^(ssh-|ecdsa-|sk-) ]]; then
    printf '%s\n' "$input"
    return 0
  fi

  # Otherwise treat it as a file path
  local expanded
  expanded=$(fc_image_expand_path "$input")
  if [[ ! -f "$expanded" ]]; then
    fc_error "SSH key file not found: $expanded"
    return 1
  fi

  fc_image_read_ssh_public_key "$expanded"
}

fc_create_main() {
  local original_args=("$@")
  local vm_name=
  local disk_size=
  local vcpus=
  local memory=
  local guest_user=
  local ssh_key_file=
  local ssh_key=

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --guest-user)
        if [[ $# -lt 2 ]]; then
          fc_error "--guest-user requires a value"
          return 1
        fi
        guest_user=$2
        shift 2
        ;;
      --ssh-key-file)
        if [[ $# -lt 2 ]]; then
          fc_error "--ssh-key-file requires a value"
          return 1
        fi
        ssh_key_file=$2
        shift 2
        ;;
      --ssh-key)
        if [[ $# -lt 2 ]]; then
          fc_error "--ssh-key requires a value"
          return 1
        fi
        ssh_key=$2
        shift 2
        ;;
      --disk-size)
        if [[ $# -lt 2 ]]; then
          fc_error "--disk-size requires a value"
          return 1
        fi
        disk_size=$2
        shift 2
        ;;
      --vcpus)
        if [[ $# -lt 2 ]]; then
          fc_error "--vcpus requires a value"
          return 1
        fi
        vcpus=$2
        shift 2
        ;;
      --memory)
        if [[ $# -lt 2 ]]; then
          fc_error "--memory requires a value"
          return 1
        fi
        memory=$2
        shift 2
        ;;
      -h|--help)
        fc_create_usage
        return 0
        ;;
      -V|--version)
        printf 'firecracker-farm %s\n' "$(fc_version)"
        return 0
        ;;
      --*)
        fc_error "Unknown argument: $1"
        fc_create_usage
        return 1
        ;;
      *)
        if [[ -n "$vm_name" ]]; then
          fc_error "unexpected positional argument: $1"
          fc_create_usage
          return 1
        fi
        vm_name=$1
        shift
        ;;
    esac
  done

  if [[ -z "$vm_name" ]]; then
    fc_error "VM name is required"
    fc_create_usage
    return 1
  fi

  # --- Sudo re-exec (before interactive prompts so credentials are only
  #     gathered once, inside the root process) ---
  if ! fc_running_as_root; then
    fc_reexec_with_sudo "$0" "${original_args[@]}"
  fi

  # --- Guest user ---
  if [[ -z "$guest_user" ]]; then
    if [[ -t 0 ]]; then
      guest_user=$(fc_create_prompt_guest_user) || return 1
    else
      fc_error "--guest-user is required when stdin is not interactive"
      return 1
    fi
  fi

  # --- SSH key ---
  if [[ -n "$ssh_key_file" && -n "$ssh_key" ]]; then
    fc_error "--ssh-key-file and --ssh-key are mutually exclusive"
    return 1
  fi

  local ssh_public_key=
  if [[ -n "$ssh_key" ]]; then
    ssh_public_key="$ssh_key"
  elif [[ -n "$ssh_key_file" ]]; then
    ssh_public_key=$(fc_create_resolve_ssh_key "$ssh_key_file") || return 1
  else
    # Interactive prompt
    if [[ -t 0 ]]; then
      local ssh_input
      ssh_input=$(fc_create_prompt_ssh_key) || return 1
      ssh_public_key=$(fc_create_resolve_ssh_key "$ssh_input") || return 1
    else
      fc_error "--ssh-key-file or --ssh-key is required when stdin is not interactive"
      return 1
    fi
  fi

  # Validate SSH key looks plausible
  if [[ ! "$ssh_public_key" =~ ^(ssh-|ecdsa-|sk-) ]]; then
    fc_error "SSH public key does not look valid (expected ssh-*, ecdsa-*, or sk-*)"
    return 1
  fi

  # --- Disk size ---
  if [[ -z "$disk_size" ]]; then
    if [[ -t 0 ]]; then
      disk_size=$(fc_image_prompt_disk_size) || return 1
    else
      fc_error "--disk-size is required when stdin is not interactive"
      return 1
    fi
  fi

  # --- vCPUs ---
  if [[ -z "$vcpus" ]]; then
    vcpus=$FC_DEFAULT_VCPUS
  fi
  if [[ ! "$vcpus" =~ ^[0-9]+$ ]] || (( vcpus < 1 )); then
    fc_error "--vcpus must be a positive integer (got: $vcpus)"
    return 1
  fi

  # --- Memory ---
  local mem_size_mib
  if [[ -z "$memory" ]]; then
    mem_size_mib=$FC_DEFAULT_MEMORY_MIB
  else
    mem_size_mib=$(fc_size_to_mib "$memory") || return 1
  fi
  if (( mem_size_mib < 128 )); then
    fc_error "--memory must be at least 128 MiB (got: ${mem_size_mib} MiB)"
    return 1
  fi

  # --- Create the VM ---
  fc_image_create_instance_disk "$vm_name" "$disk_size" "$guest_user" "$ssh_public_key" || return 1
  fc_network_prepare_instance_metadata "$vm_name" "$(fc_image_instance_metadata_path "$vm_name")"

  # Write per-instance compute parameters to vm.env
  local metadata_path
  metadata_path=$(fc_image_instance_metadata_path "$vm_name")
  cat >> "$metadata_path" <<EOF
VCPU_COUNT=$vcpus
MEM_SIZE_MIB=$mem_size_mib
GUEST_USER=$guest_user
EOF
}

fc_create_main "$@"
